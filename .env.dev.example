# Copy to .env.dev — local values only, never commit real keys
AZURE_STORAGE_CONNECTION_STRING="UseDevelopmentStorage=true"
# Use service hostnames inside Docker; use localhost when running services on the host
POSTGRES_DSN="postgresql://devuser:devpass@postgres:5432/voice_agent_dev"
REDIS_URL="redis://redis:6379"
OPENAI_API_KEY="sk-..."
DEEPGRAM_API_KEY="..."
ELEVENLABS_API_KEY="..."
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
LANGSMITH_API_KEY="..."
AGENT_BRAIN_URL="http://agent-brain:8001"
BUSINESS_NAME="Test Home Services"

LIVEKIT_URL="wss://your-project.livekit.cloud"
LIVEKIT_API_KEY="..."
LIVEKIT_API_SECRET="..."
LIVEKIT_SIP_DOMAIN="your-project.sip.livekit.cloud"
LIVEKIT_SIP_TRUNK_ID="ST_xxxxxxxx"

# TTS: deepgram (free Aura voices) or elevenlabs (paid plan for library voices)
TTS_PROVIDER="deepgram"
DEEPGRAM_TTS_MODEL="aura-2-thalia-en"
ELEVENLABS_VOICE_ID="your-voice-id-from-my-voices"
ELEVENLABS_MODEL_ID="eleven_turbo_v2_5"

# Voice path: twilio_stream (recommended) or livekit_sip
VOICE_TRANSPORT="twilio_stream"
# Your ngrok HTTPS URL — Twilio connects here for Media Streams (no trailing slash)
PUBLIC_BASE_URL="https://your-subdomain.ngrok-free.app"
